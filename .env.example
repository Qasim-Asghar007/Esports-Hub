# ── EsportsHub Frontend Environment Variables ─────────────────────────
# Copy this file to .env and fill in your values

# ── Backend API ──────────────────────────────────────────────────────
# Leave empty to use MockDB (no backend needed)
# Set to your backend URL to use the real backend
VITE_API_BASE_URL=

# With backend running locally:
# VITE_API_BASE_URL=http://localhost:3001

# ── Gemini AI Support Bot ────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY=
